    {
      "id": "u3cB0Va8ZJLApihii-TEn",
      "type": "text",
      "x": 8417.08845869839,
      "y": 1473.204918903308,
      "width": 270.8720628455979,
      "height": 225.04312763082984,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bZ9",
      "roundness": null,
      "seed": 1493182490,
      "version": 1905,
      "versionNonce": 1015888499,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1768489999155,
      "link": null,
      "locked": false,
      "text": "1. If the user sent audio, the placeholder\n\"Voice message\" bubble is replaced with the\nactual text (transcript) returned by the\nserver\n\n2. The new assistant message is added to\nthe list\n\n3. Automatically play the Mandarin text\n\n4. The app calls recordConversationTurn() to\ntrack user activity\n\n5. If the server flagged conversationComplete\nConfetti animation plays",
      "fontSize": 12.002300140310926,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. If the user sent audio, the placeholder \"Voice message\" bubble is replaced with the actual text (transcript) returned by the server\n\n2. The new assistant message is added to the list\n\n3. Automatically play the Mandarin text\n\n4. The app calls recordConversationTurn() to track user activity\n\n5. If the server flagged conversationComplete Confetti animation plays",
      "autoResize": false,
      "lineHeight": 1.25
    },

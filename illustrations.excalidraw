    {
      "id": "z6nvJjt4VIAsZU5nhxuoP",
      "type": "text",
      "x": 14929.396640392577,
      "y": 5696.157969641971,
      "width": 674.9594116210938,
      "height": 40,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],

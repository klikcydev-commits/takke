      "link": null,
      "locked": false,
      "text": "Backend generates another presigned URL for the file that was\npreviously uploaded to the S3 bucket. Navigating to this URL\ndownloads the file. Link is valid for 1 hour.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Backend generates another presigned URL for the file that was previously uploaded to the S3 bucket. Navigating to this URL downloads the file. Link is valid for 1 hour.",
      "autoResize": false,
      "lineHeight": 1.25
    },

      "updated": 1772485477856,
      "link": null,
      "locked": false,
      "text": "Set a limit for LLM usage per user. You can track\nusage for non-premium users in the edge functions,\nand set a daily limit. Show an error toast if limit is\nhit.",
      "fontSize": 16.044410310975934,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "vvh4IzswOr3lN28SxgNuM",
      "originalText": "Set a limit for LLM usage per user. You can track usage for non-premium users in the edge functions, and set a daily limit. Show an error toast if limit is hit.",
      "autoResize": true,
      "lineHeight": 1.25
    },

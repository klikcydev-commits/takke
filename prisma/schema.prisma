generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

// ==========================================
// 1. Enums
// ==========================================
enum RoleType {
  CUSTOMER
  STORE_OWNER
  DELIVERY_DRIVER
  ADMIN
  SUPER_ADMIN
}

enum StoreStatus {
  PENDING
  INFO_REQUESTED
  APPROVED
  REJECTED
  SUSPENDED
}

enum StoreType {
  RETAIL
  WHOLESALE
  SUPPLIER_STYLE
  MARKETPLACE_SELLER
}

enum ProductStatus {
  DRAFT
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
  ARCHIVED
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  CONFIRMED
  PREPARING
  READY_FOR_PICKUP
  PICKED_UP
  ON_THE_WAY
  NEAR_CUSTOMER
  DELIVERED
  CANCELLED
  RETURNED
  REFUNDED
  FAILED_DELIVERY
  PARTIALLY_DELIVERED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
}

enum DeliveryStatus {
  ASSIGNED
  ACCEPTED
  REJECTED
  PICKUP_ARRIVED
  PICKED_UP
  ON_THE_WAY
  NEAR_CUSTOMER
  DELIVERED
  FAILED
}

enum CouponStatus {
  ACTIVE
  EXPIRED
  INACTIVE
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  REJECTED
}

enum RefundStatus {
  PENDING
  APPROVED
  REJECTED
  PROCESSED
}

enum ReturnStatus {
  PENDING
  APPROVED
  REJECTED
  SHIPPED
  RECEIVED
  COMPLETED
}

enum ActivityType {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  ADMIN_ACTION
}

// ==========================================
// 2. Auth / User
// ==========================================
model User {
  id              String    @id @default(uuid())
  /// Supabase Auth user id (`auth.users.id`) when using Supabase Auth; links session JWT `sub` to app user.
  authUserId      String?   @unique @map("auth_user_id") @db.Uuid
  email           String    @unique
  hashedPassword  String?
  isEmailVerified Boolean   @default(false)
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  userProfile      UserProfile?
  authAccounts     AuthAccount[]
  emailVerifications EmailVerification[]
  passwordResets   PasswordReset[]
  refreshTokens    RefreshToken[]
  sessions         UserSession[]
  deviceTokens     DeviceToken[]
  roles            UserRoleAssignment[]
  addresses        Address[]
  carts            Cart[]
  wishlists        Wishlist[]
  favorites        Favorite[]
  orders           Order[]
  store            Store?
  driver           Driver?
  reviews          Review[]
  supportTickets   SupportTicket[]
  disputes         Dispute[]
  refundRequests   RefundRequest[]
  returnRequests   ReturnRequest[]
  auditLogs        AdminAuditLog[] @relation("AdminAuditLogs")
  activityLogs     ActivityLog[]
  notifications    Notification[]
  driverApplications DriverApplication[]
  
  // Application fields
  requestedRole    RoleType?
  onboardingStatus String    @default("NONE") // NONE, PENDING, APPROVED, REJECTED, INFO_REQUESTED
}

model UserProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  firstName String
  lastName  String
  phone     String?
  avatarUrl String?
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuthAccount {
  id                String   @id @default(uuid())
  userId            String
  provider          String   // google, apple
  providerAccountId String
  createdAt         DateTime @default(now())

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model EmailVerification {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordReset {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSession {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  ipAddress String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DeviceToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  deviceType String? // ios, android, web
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Role {
  id          String   @id @default(uuid())
  name        RoleType @unique
  description String?
  
  assignments UserRoleAssignment[]
}

model UserRoleAssignment {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

// ==========================================
// 3. Address / Customer
// ==========================================
model Address {
  id           String   @id @default(uuid())
  userId       String
  label        String?
  street       String
  city         String
  state        String
  postalCode   String
  country      String
  isDefault    Boolean  @default(false)
  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Cart {
  id        String     @id @default(uuid())
  userId    String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
}

model CartItem {
  id               String         @id @default(uuid())
  cartId           String
  productId        String
  productVariantId String
  quantity         Int
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  cart             Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product          Product        @relation(fields: [productId], references: [id])
  variant          ProductVariant @relation(fields: [productVariantId], references: [id])
}

model Wishlist {
  id        String         @id @default(uuid())
  userId    String
  name      String         @default("Main")
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     WishlistItem[]
}

model WishlistItem {
  id               String         @id @default(uuid())
  wishlistId       String
  productId        String
  createdAt        DateTime       @default(now())

  wishlist         Wishlist       @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  product          Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  storeId   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

// ==========================================
// 4. Vendor / Store
// ==========================================
model Store {
  id            String      @id @default(uuid())
  ownerId       String      @unique
  name          String
  slug          String      @unique
  description   String?
  status        StoreStatus @default(PENDING)
  type          StoreType   @default(RETAIL)
  deletedAt     DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  owner               User                @relation(fields: [ownerId], references: [id])
  profile             StoreProfile?
  documents           StoreDoc[]
  bankAccount         StoreBankAccount?
  operatingHours      StoreOperatingHour[]
  deliveryZones       StoreDeliveryZone[]
  products            Product[]
  orderItems          OrderItem[]
  favorites           Favorite[]
  applications        StoreApplication[]
  payouts             VendorPayout[]
  pickupEvents        PickupEvent[]
}

model StoreProfile {
  id               String   @id @default(uuid())
  storeId          String   @unique
  logoUrl          String?
  bannerUrl        String?
  businessEmail    String?
  businessPhone    String?
  businessAddress  String?
  metadata         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  store            Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model StoreDoc {
  id        String   @id @default(uuid())
  storeId   String
  name      String   // e.g. "Business License"
  url       String
  type      String   // PDF, Image
  createdAt DateTime @default(now())

  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model StoreBankAccount {
  id            String   @id @default(uuid())
  storeId       String   @unique
  bankName      String
  accountNumber String
  routingNumber String?
  holderName    String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  store         Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model StoreOperatingHour {
  id        String   @id @default(uuid())
  storeId   String
  dayOfWeek Int      // 0-6
  openTime  String   // HH:mm
  closeTime String   // HH:mm
  isOpen    Boolean  @default(true)

  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model StoreDeliveryZone {
  id        String   @id @default(uuid())
  storeId   String
  name      String
  radiusKm  Float?
  polygon   Json?    // GeoJSON
  createdAt DateTime @default(now())

  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model StoreApplication {
  id          String      @id @default(uuid())
  storeId     String
  status      StoreStatus @default(PENDING)
  notes       String?
  reviewedBy  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  store       Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  history     StoreApplicationStatusHistory[]
}

model StoreApplicationStatusHistory {
  id                 String           @id @default(uuid())
  applicationId      String
  status             StoreStatus
  notes              String?
  createdAt          DateTime         @default(now())

  application        StoreApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

// ==========================================
// 5. Product
// ==========================================
model ProductCategory {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  parentId    String?
  imageUrl    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  parent      ProductCategory?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  children    ProductCategory[] @relation("CategoryToCategory")
  products    Product[]
}

model Product {
  id            String        @id @default(uuid())
  storeId       String
  categoryId    String
  title         String
  slug          String        @unique
  description   String
  basePrice     Float
  status        ProductStatus @default(DRAFT)
  deletedAt     DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  store         Store            @relation(fields: [storeId], references: [id])
  category      ProductCategory  @relation(fields: [categoryId], references: [id])
  variants      ProductVariant[]
  images        ProductImage[]
  attributes    ProductAttribute[]
  cartItems     CartItem[]
  wishlistItems WishlistItem[]
  reviews       Review[]
  statusHistory ProductStatusHistory[]
}

model ProductStatusHistory {
  id        String        @id @default(uuid())
  productId String
  status    ProductStatus
  notes     String?
  createdAt DateTime      @default(now())

  product   Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductVariant {
  id          String   @id @default(uuid())
  productId   String
  sku         String   @unique
  salePrice   Float?
  stock       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product     Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems   CartItem[]
  orderItems  OrderItem[]
  attributeValues ProductVariantAttributeValue[]
  inventory   Inventory?
}

model Inventory {
  id               String           @id @default(uuid())
  productVariantId String           @unique
  quantity         Int              @default(0)
  lowStockThreshold Int             @default(5)
  updatedAt        DateTime         @updatedAt

  variant          ProductVariant   @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  movements        StockMovement[]
}

model StockMovement {
  id          String   @id @default(uuid())
  inventoryId String
  quantity    Int      // positive for restock, negative for sales
  type        String   // RESTOCK, SALE, ADJUSTMENT, RETURN
  notes       String?
  createdAt   DateTime @default(now())

  inventory   Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  url       String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductAttribute {
  id        String   @id @default(uuid())
  productId String
  name      String   // e.g. "Size", "Color"
  
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  values    ProductVariantAttributeValue[]
}

model ProductVariantAttributeValue {
  id                 String           @id @default(uuid())
  productVariantId   String
  productAttributeId String
  value              String           // e.g. "XL", "Red"

  variant            ProductVariant   @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  attribute          ProductAttribute @relation(fields: [productAttributeId], references: [id], onDelete: Cascade)

  @@unique([productVariantId, productAttributeId])
}

// ==========================================
// 6. Order / Checkout
// ==========================================
model Order {
  id             String      @id @default(uuid())
  customerId     String
  orderNumber    String      @unique
  subtotal       Float
  deliveryFee    Float       @default(0)
  discount       Float       @default(0)
  totalAmount    Float
  currentStatus  OrderStatus @default(PENDING_PAYMENT)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  customer       User                @relation(fields: [customerId], references: [id])
  items          OrderItem[]
  notes          OrderNote[]
  cancellations  OrderCancellation?
  statusHistory  OrderStatusHistory[]
  payment        Payment?
  address        OrderAddress?
  couponRedemptions CouponRedemption[]
  disputes          Dispute[]
}

model OrderItem {
  id               String      @id @default(uuid())
  orderId          String
  storeId          String
  productId        String
  productVariantId String
  quantity         Int
  basePrice        Float
  salePrice        Float?
  subtotal         Float
  titleSnapshot    String
  skuSnapshot      String
  variantLabelSnapshot String?
  currentStatus    OrderStatus @default(PENDING_PAYMENT)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  order            Order                   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  store            Store                   @relation(fields: [storeId], references: [id])
  variant          ProductVariant          @relation(fields: [productVariantId], references: [id])
  statusHistory    OrderItemStatusHistory[]
  deliveryItems    DeliveryAssignmentItem[]
  pickupItems      PickupEventItem[]
  commission       Commission?
  refundRequest    RefundRequest?
  returnRequest    ReturnRequest?
}

model OrderAddress {
  id            String   @id @default(uuid())
  orderId       String   @unique
  street        String
  city          String
  state         String
  postalCode    String
  country       String
  snapshotLabel String?

  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model OrderNote {
  id        String   @id @default(uuid())
  orderId   String
  authorId  String
  note      String
  createdAt DateTime @default(now())

  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model OrderCancellation {
  id        String   @id @default(uuid())
  orderId   String   @unique
  reason    String
  notes     String?
  createdAt DateTime @default(now())

  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model OrderStatusHistory {
  id        String      @id @default(uuid())
  orderId   String
  status    OrderStatus
  notes     String?
  createdAt DateTime    @default(now())

  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model OrderItemStatusHistory {
  id          String      @id @default(uuid())
  orderItemId String
  status      OrderStatus
  notes       String?
  createdAt   DateTime    @default(now())

  orderItem   OrderItem   @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
}

// ==========================================
// 7. Payment / Finance
// ==========================================
model Payment {
  id            String        @id @default(uuid())
  orderId       String        @unique
  amount        Float
  currency      String        @default("USD")
  provider      String        // stripe, manual
  transactionId String?
  status        PaymentStatus @default(PENDING)
  metadata      Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  order         Order         @relation(fields: [orderId], references: [id])
}

model Coupon {
  id            String       @id @default(uuid())
  code          String       @unique
  description   String?
  discountType  String       // PERCENTAGE, FIXED_AMOUNT
  discountValue Float
  minSpend      Float?
  maxDiscount   Float?
  expiresAt     DateTime?
  usageLimit    Int?
  usageCount    Int          @default(0)
  status        CouponStatus @default(ACTIVE)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  redemptions   CouponRedemption[]
}

model CouponRedemption {
  id        String   @id @default(uuid())
  couponId  String
  orderId   String
  amount    Float
  createdAt DateTime @default(now())

  coupon    Coupon   @relation(fields: [couponId], references: [id])
  order     Order    @relation(fields: [orderId], references: [id])
}

model Commission {
  id          String    @id @default(uuid())
  orderItemId String    @unique
  rate        Float     // percentage
  amount      Float
  payoutId    String?
  createdAt   DateTime  @default(now())

  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])
  payout      VendorPayout? @relation(fields: [payoutId], references: [id])
}

model VendorPayout {
  id            String   @id @default(uuid())
  storeId       String
  amount        Float
  status        String   // PENDING, PROCESSED, FAILED
  reference     String?
  processedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  store         Store    @relation(fields: [storeId], references: [id])
  items         PayoutItem[]
  commissions   Commission[]
}

model PayoutItem {
  id           String       @id @default(uuid())
  payoutId     String
  orderItemId  String       @unique
  amount       Float
  createdAt    DateTime     @default(now())

  payout       VendorPayout @relation(fields: [payoutId], references: [id])
}

// ==========================================
// 8. Delivery Operations
// ==========================================
model Driver {
  id            String   @id @default(uuid())
  userId        String   @unique
  vehicleType   String?
  licensePlate  String?
  isActive      Boolean  @default(true)
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments   DeliveryAssignment[]
  applications  DriverApplication[]
  pickupEvents  PickupEvent[]
}

model DriverApplication {
  id              String      @id @default(uuid())
  userId          String
  status          StoreStatus @default(PENDING) // Reusing StoreStatus for consistency: PENDING, APPROVED, REJECTED
  
  // Personal Info Snapshot
  fullName        String
  dateOfBirth     DateTime?
  
  // Vehicle Info
  vehicleType     String
  vehicleModel    String
  licensePlate    String
  
  // Documents (URLs)
  identityDocUrl   String
  licenseDocUrl    String
  insuranceDocUrl  String?
  registrationDocUrl String?
  
  // Payout Info
  bankName        String?
  accountNumber   String?
  
  adminNotes      String?
  reviewedBy      String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  driver          Driver?     @relation(fields: [userId], references: [userId], map: "DriverApplication_driver_fkey")
  history         DriverApplicationStatusHistory[]
}

model DriverApplicationStatusHistory {
  id                 String            @id @default(uuid())
  applicationId      String
  status             StoreStatus
  notes              String?
  createdAt          DateTime          @default(now())

  application        DriverApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model Notification {
  id          String   @id @default(uuid())
  userId      String
  title       String
  message     String
  type        String   // APPLICATION_STATUS, ORDER_UPDATE, SYSTEM
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DeliveryAssignment {
  id          String         @id @default(uuid())
  driverId    String?
  status      DeliveryStatus @default(ASSIGNED)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  driver      Driver?                  @relation(fields: [driverId], references: [id])
  items       DeliveryAssignmentItem[]
  tracking    DeliveryTrackingUpdate[]
  proofs      DeliveryProof[]
  failures    FailedDeliveryAttempt[]
}

model DeliveryAssignmentItem {
  id            String             @id @default(uuid())
  assignmentId  String
  orderItemId   String

  assignment    DeliveryAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  orderItem     OrderItem          @relation(fields: [orderItemId], references: [id])
}

model PickupEvent {
  id          String             @id @default(uuid())
  driverId    String?
  storeId     String
  createdAt   DateTime           @default(now())

  store       Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  driver      Driver?            @relation(fields: [driverId], references: [id], onDelete: SetNull)
  items       PickupEventItem[]
}

model PickupEventItem {
  id            String      @id @default(uuid())
  pickupEventId String
  orderItemId   String

  pickupEvent   PickupEvent @relation(fields: [pickupEventId], references: [id], onDelete: Cascade)
  orderItem     OrderItem   @relation(fields: [orderItemId], references: [id])
}

model DeliveryTrackingUpdate {
  id            String             @id @default(uuid())
  assignmentId  String
  status        DeliveryStatus
  locationLat   Float?
  locationLng   Float?
  notes         String?
  createdAt     DateTime           @default(now())

  assignment    DeliveryAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
}

model DeliveryProof {
  id            String             @id @default(uuid())
  assignmentId  String
  imageUrl      String
  notes         String?
  createdAt     DateTime           @default(now())

  assignment    DeliveryAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
}

model FailedDeliveryAttempt {
  id            String             @id @default(uuid())
  assignmentId  String
  reason        String
  notes         String?
  createdAt     DateTime           @default(now())

  assignment    DeliveryAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
}

// ==========================================
// 9. Review / Support / Disputes
// ==========================================
model Review {
  id        String   @id @default(uuid())
  userId    String
  productId String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])
  reply     ReviewReply?
}

model ReviewReply {
  id        String   @id @default(uuid())
  reviewId  String   @unique
  authorId  String   // Store owner user id
  comment   String
  createdAt DateTime @default(now())

  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}

model SupportTicket {
  id        String   @id @default(uuid())
  userId    String
  subject   String
  status    String   // OPEN, IN_PROGRESS, RESOLVED
  priority  String   // LOW, MEDIUM, HIGH, URGENT
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])
  messages  SupportTicketMessage[]
}

model SupportTicketMessage {
  id        String   @id @default(uuid())
  ticketId  String
  authorId  String
  message   String
  createdAt DateTime @default(now())

  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model Dispute {
  id            String        @id @default(uuid())
  orderId       String
  userId        String        // Customer opening dispute
  reason        String
  status        DisputeStatus @default(OPEN)
  resolution    String?
  reviewedBy    String?       // Admin user id
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id])
}

model RefundRequest {
  id          String       @id @default(uuid())
  orderItemId String       @unique
  userId      String
  amount      Float
  reason      String
  status      RefundStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user        User         @relation(fields: [userId], references: [id])
  orderItem   OrderItem    @relation(fields: [orderItemId], references: [id])
}

model ReturnRequest {
  id          String       @id @default(uuid())
  orderItemId String       @unique
  userId      String
  reason      String
  status      ReturnStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user        User         @relation(fields: [userId], references: [id])
  orderItem   OrderItem    @relation(fields: [orderItemId], references: [id])
}

// ==========================================
// 10. System / Admin
// ==========================================
model HomepageBanner {
  id        String   @id @default(uuid())
  title     String?
  imageUrl  String
  linkUrl   String?
  isActive  Boolean  @default(true)
  priority  Int      @default(0)
  createdAt DateTime @default(now())
}

model AppSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminAuditLog {
  id        String   @id @default(uuid())
  adminId   String
  action    String
  entity    String   // table name
  entityId  String
  oldData   Json?
  newData   Json?
  createdAt DateTime @default(now())

  admin     User     @relation("AdminAuditLogs", fields: [adminId], references: [id])
}

model ActivityLog {
  id        String       @id @default(uuid())
  userId    String?
  type      ActivityType
  action    String
  metadata  Json?
  createdAt DateTime     @default(now())

  user      User?        @relation(fields: [userId], references: [id])
}

      "link": null,
      "locked": false,
      "text": "Dubbing is taking a video with e.g. English\nspeaking, and making the speaker speak another\nlanguage. Lip movements should also match the\nnew language.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Dubbing is taking a video with e.g. English speaking, and making the speaker speak another language. Lip movements should also match the new language.",
      "autoResize": false,
      "lineHeight": 1.25
    },

    {
      "id": "1K-ipQWwCn-ViEzS6niPT",
      "type": "text",
      "x": 16520.383548041806,
      "y": -532.6984904094695,
      "width": 633.2312941656619,
      "height": 180,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bPW",
      "roundness": null,
      "seed": 1533333235,
      "version": 4006,
      "versionNonce": 1000077811,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1768490391854,
      "link": null,
      "locked": false,
      "text": "Creating a song consists of a series of steps.\n\n1. Get the info required to generate video from database\n2. Text-to-speech done in our Modal backend\n3. Submitting a job to Sieve\n4. Deduction credits\n\nI want to execute the steps in the background. So when the user clicks\ngenerate, our app should execute these steps in a durable way.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Creating a song consists of a series of steps.\n\n1. Get the info required to generate video from database\n2. Text-to-speech done in our Modal backend\n3. Submitting a job to Sieve\n4. Deduction credits\n\nI want to execute the steps in the background. So when the user clicks generate, our app should execute these steps in a durable way.",
      "autoResize": false,
      "lineHeight": 1.25
    },

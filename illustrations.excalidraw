    },
    {
      "id": "tV80JTv-EW-i6TLt6Zh0r",
      "type": "text",
      "x": 16284.47952049847,
      "y": 1871.9182339692825,
      "width": 633.2312941656619,
      "height": 140,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bTk",
      "roundness": null,
      "seed": 1151737687,
      "version": 5087,
      "versionNonce": 922902803,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1768490442691,
      "link": null,
      "locked": false,
      "text": "We'll use Polar for handling payments for this project\n- Polar x BetterAuth integration is sweet. \n- Automatic customer creation, storing of customer id's etc. Keeps our setup\nsimple.\n- Available in more countries than Stripe\n- Less mature compared to Stripe, but generally simpler to work with for the\nkind of payments we will set up",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "We'll use Polar for handling payments for this project\n- Polar x BetterAuth integration is sweet. \n- Automatic customer creation, storing of customer id's etc. Keeps our setup simple.\n- Available in more countries than Stripe\n- Less mature compared to Stripe, but generally simpler to work with for the kind of payments we will set up",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "cOPFp18vba8GHA28IOf0A",

      "link": null,
      "locked": false,
      "text": "Lipsync synchronizes the lip movements in a video\nwith another audio track. I.e. replacing the audio\nin a video, and making it look like the speaker\nactually said that.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Lipsync synchronizes the lip movements in a video with another audio track. I.e. replacing the audio in a video, and making it look like the speaker actually said that.",

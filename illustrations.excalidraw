      "seed": 1178821771,
      "version": 823,
      "versionNonce": 47355133,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1768490351712,
      "link": null,
      "locked": false,
      "text": "Inference: still photo to video avatar like hallo3\n\nSievedata offers multiple different models and\ngeneration options though",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Inference: still photo to video avatar like hallo3\n\nSievedata offers multiple different models and generation options though",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "BxwD8elVppyXlnkbkWep9",
      "type": "text",
      "x": 14020.931544090377,
      "y": 1094.9343096979933,
      "width": 381.30197192543517,
      "height": 60,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bK9",
      "roundness": null,
      "seed": 1365969419,
      "version": 690,
      "versionNonce": 957023571,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1768490351712,
      "link": null,
      "locked": false,
      "text": "It's a cool way to see how our system can\nsupport multiple AI backends at the same time,\ninstead of only just our own.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "It's a cool way to see how our system can support multiple AI backends at the same time, instead of only just our own.",
      "autoResize": false,
      "lineHeight": 1.25
    },

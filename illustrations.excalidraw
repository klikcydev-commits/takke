    {
      "id": "_titOyAWeLGFsJ1knDars",
      "type": "text",
      "x": 6228.462214425095,
      "y": 267.6675565509901,
      "width": 424.66532216757173,
      "height": 180.0345021046639,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bWu",
      "roundness": null,
      "seed": 863432774,
      "version": 1294,
      "versionNonce": 786817629,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1768490758621,
      "link": null,
      "locked": false,
      "text": "1. Client sends request to the Supabase project Auth API\n\n2. Supabase checks if the user exists (or creates a new) and generates\na unique \"Magic Link\" token\n\n3. Supabase sends an email to the address provided. This email contains\na link with the token\n\n4. The emailRedirectTo parameter is stored with the token request.\nWhen the user clicks the link, they are redirected back to your app\n(deep linking)\n",
      "fontSize": 12.002300140310926,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. Client sends request to the Supabase project Auth API\n\n2. Supabase checks if the user exists (or creates a new) and generates a unique \"Magic Link\" token\n\n3. Supabase sends an email to the address provided. This email contains a link with the token\n\n4. The emailRedirectTo parameter is stored with the token request. When the user clicks the link, they are redirected back to your app (deep linking)\n",
      "autoResize": false,
      "lineHeight": 1.25
    },

      "boundElements": [],
      "updated": 1768490351712,
      "link": null,
      "locked": false,
      "text": "\"We acknowledge your webhook.\"\nI.e. We've saved the URL\npointing to the generated video,\nor if the generation failed, we've\nregister and can show the user\nthat.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\"We acknowledge your webhook.\"\nI.e. We've saved the URL pointing to the generated video, or if the generation failed, we've register and can show the user that.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "vYWQBYhyICwhzlfU-dd7i",
      "type": "text",
      "x": 14372.5653061872,
      "y": 2698.574244447732,
      "width": 576.6715087890625,
      "height": 40,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bM7",
      "roundness": null,
      "seed": 93783397,
      "version": 472,
      "versionNonce": 1565635027,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1768490351712,
      "link": null,
      "locked": false,
      "text": "The Sieve server sends a webhook (request) back to our next.js backend.\nWe tell Sieve where they should send the webhook",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The Sieve server sends a webhook (request) back to our next.js backend.\nWe tell Sieve where they should send the webhook",
      "autoResize": true,
      "lineHeight": 1.25
    },

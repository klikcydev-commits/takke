    {
      "id": "yaTSTmBfpDJNLp3dF8CQr",
      "type": "text",
      "x": 8417.1946614514,
      "y": 1185.7569439898657,
      "width": 270.8720628455979,
      "height": 195.03737728005254,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",

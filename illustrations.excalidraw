      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Authentication happens with Supabase auth, since it's one of the established players in the mobile development front.\n\nOther viable solutions include:",
      "autoResize": false,
      "lineHeight": 1.25
    },

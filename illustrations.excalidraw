      "isDeleted": true,
      "boundElements": [],
      "updated": 1768490391854,
      "link": null,
      "locked": false,
      "text": "Each event is a request for\ngenerating one of the videos we\nsupport.\n\nAn event contains the\ninformation required to generate\nit, e.g. S3 keys to the source\nphotos, scripts or audio S3 keys",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Each event is a request for generating one of the videos we support.\n\nAn event contains the information required to generate it, e.g. S3 keys to the source photos, scripts or audio S3 keys",
      "autoResize": false,
      "lineHeight": 1.25
    },

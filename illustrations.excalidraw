    {
      "id": "5q9m9x5pOi6UdL8HW7gQR",
      "type": "text",
      "x": 6308.419785798069,
      "y": 1307.8102443145415,
      "width": 926.1287570529503,
      "height": 250,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "be5",
      "roundness": null,
      "seed": 948223140,
      "version": 1602,
      "versionNonce": 434835108,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1768557127887,
      "link": null,
      "locked": false,
      "text": "Framework we can use to create mobile and web apps with react.\n\nBuilds on top of react-native.\n\nI see it as Next.js, but for mobile dev. Has APIs for all the things you need for mobile dev.\n- Notification\n- Local storage\n- Micrpohone\n- Camera etc\n- All the things you'd have to figure out how to use yourself without it",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Framework we can use to create mobile and web apps with react.\n\nBuilds on top of react-native.\n\nI see it as Next.js, but for mobile dev. Has APIs for all the things you need for mobile dev.\n- Notification\n- Local storage\n- Micrpohone\n- Camera etc\n- All the things you'd have to figure out how to use yourself without it",
      "autoResize": false,
      "lineHeight": 1.25
    },

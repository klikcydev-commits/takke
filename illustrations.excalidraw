    {
      "id": "IOHdvxCChBgU2QMZG35qC",
      "type": "text",
      "x": 15032.07269578582,
      "y": 1648.7573930861363,
      "width": 299.26373291015625,
      "height": 120,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],

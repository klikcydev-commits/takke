    {
      "id": "rGT5fGzYDZ6IKdDOO3X3t",
      "type": "text",
      "x": 8416.188229695777,
      "y": 652.4464647019944,
      "width": 270.8720628455979,
      "height": 60.011500701554624,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bYr",
      "roundness": null,
      "seed": 1997474566,
      "version": 1543,
      "versionNonce": 1950579219,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1768489999154,
      "link": null,
      "locked": false,
      "text": "** Client keeps track of current messages **\n\n1. It loads with a predefined \"Hello!\" (你好！)\nmessage from the assistant",
      "fontSize": 12.002300140310926,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "** Client keeps track of current messages **\n\n1. It loads with a predefined \"Hello!\" (你好！) message from the assistant",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "1y3dyjetaqAq-7K472NBX",
      "type": "rectangle",
      "x": 8396.974309437652,
      "y": 639.8136789067472,
      "width": 302.19618448128915,
      "height": 85.01323806026416,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bYs",
      "roundness": {
        "type": 3
      },
      "seed": 943962694,
      "version": 1116,
      "versionNonce": 546357171,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "fVKpynqpLO_RXwrWfWoXn",
          "type": "arrow"
        },
        {
          "id": "izCPO5RomnEr4XD_W4mql",
          "type": "arrow"
        }
      ],
      "updated": 1768489999154,
      "link": null,
      "locked": false
    },
    {
      "id": "v8BxWWkTrtTEnpbU_iEJC",
      "type": "text",
      "x": 8203.731426929828,
      "y": 796.9986637082618,
      "width": 270.8720628455979,
      "height": 165.0316269292752,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bYt",
      "roundness": null,
      "seed": 40286406,
      "version": 1732,
      "versionNonce": 174346579,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1768489999155,
      "link": null,
      "locked": false,
      "text": "1. User types in the text input and presses\nSend.\n\n2. User's message is immediately added to\nthe chat list.\n\n3. The app calls the Supabase Edge Function\nchat-completion with the full message history\n(including the new user message).\n\n4. A loading spinner appears",
      "fontSize": 12.002300140310926,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. User types in the text input and presses Send.\n\n2. User's message is immediately added to the chat list.\n\n3. The app calls the Supabase Edge Function chat-completion with the full message history (including the new user message).\n\n4. A loading spinner appears",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "tddgsxqU-VeRQ8pX4M0Uf",
      "type": "rectangle",
      "x": 8184.3404248910865,
      "y": 784.2165675368715,
      "width": 302.19618448128915,
      "height": 192.73741807969256,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bYu",
      "roundness": {
        "type": 3
      },
      "seed": 1608495110,
      "version": 1502,
      "versionNonce": 1125428979,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "izCPO5RomnEr4XD_W4mql",
          "type": "arrow"
        },
        {
          "id": "lDGBOftX20oSWwyxQ42DF",
          "type": "arrow"
        }
      ],
      "updated": 1768489999155,
      "link": null,
      "locked": false
    },
    {
      "id": "PZfMso3Y49DCJq4PGwHkP",
      "type": "text",
      "x": 8630.145091394172,
      "y": 797.003280788979,
      "width": 270.8720628455979,
      "height": 285.0546283323845,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bYv",
      "roundness": null,
      "seed": 677978138,
      "version": 1948,
      "versionNonce": 1831360659,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1768489999155,
      "link": null,
      "locked": false,
      "text": "1. User taps the mic button. The app\nrequests permissions, configures the audio\nsession and starts recording to a .wav file.\n\n2. User taps stop\n\n3. The app reads the local audio file as a\nBase64 string.\n\n4.  A placeholder bubble with text \"Voice\nmessage\" is added to the chat.\n\n5. The app calls the same chat-completion\nEdge Function but includes an extra\ninputAudio object containing the Base64\ndata.\n\n** The same backend handles transcription\nand response in one go. **",
      "fontSize": 12.002300140310926,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. User taps the mic button. The app requests permissions, configures the audio session and starts recording to a .wav file.\n\n2. User taps stop\n\n3. The app reads the local audio file as a Base64 string.\n\n4.  A placeholder bubble with text \"Voice message\" is added to the chat.\n\n5. The app calls the same chat-completion Edge Function but includes an extra inputAudio object containing the Base64 data.\n\n** The same backend handles transcription and response in one go. **",
      "autoResize": false,
      "lineHeight": 1.25
    },

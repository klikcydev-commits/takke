    {
      "id": "2gQ2vy7QHkNTLguuEYUml",
      "type": "text",
      "x": 16631.539284713697,
      "y": 835.7766474538015,
      "width": 256.86488183523227,
      "height": 160,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",

# =============================================================================
# Marketplace monorepo — copy to .env at repo root and fill values.
# Prefer pasting connection strings from Supabase Dashboard → Connect (exact copy).
# =============================================================================

# --- Prisma / Postgres (Supabase) ---
#
# Paste **exact** connection strings from Supabase → **Connect**. Do not hand-roll hostnames or regions.
#
# DATABASE_URL — Next.js `/api` route handlers, tooling, `prisma db seed` (pooled connections)
#   Connect → **Transaction pooler** (Supavisor) — port **6543**
#   User: postgres.<PROJECT_REF>  |  Append: ?pgbouncer=true
#
# DIRECT_URL — Prisma CLI only (`migrate`, `db push`, `studio`)
#   Connect → **Session pooler** (Supavisor) — port **5432** (same pooler host family as above, different port)
#   User: postgres.<PROJECT_REF>  |  Paste the full URI from the dashboard.
#
# IPv4 / connectivity: If **Direct connection** (`db.<project>.supabase.co:5432`) fails with P1001 from your PC,
# do not use it for Prisma CLI — keep using **Session pooler :5432** for DIRECT_URL (this is expected on many networks).
#
# Errors: "Tenant or user not found" → reset database password (Settings → Database), re-copy both URLs.
# Encode special characters in passwords in the URL (e.g. ! → %21).

DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Replace with the Session pooler string from Connect (ends with :5432), not a guessed host:
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# --- Supabase project (Dashboard → Settings → API) ---
# Authentication → URL Configuration: set Site URL to how you open the app locally (e.g. http://localhost:3000).
# Under Redirect URLs add at least: http://localhost:3000/** and http://127.0.0.1:3000/** (and your LAN URL if you use it).
# For local dev you can disable Authentication → Providers → Email → "Confirm email" to skip inbox verification.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
# Dashboard “Connect your app” often labels this as Publishable key (sb_publishable_…):
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your_publishable_key"
# Legacy names (optional if PUBLISHABLE_KEY is set):
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_anon_public_key"
NEXT_PUBLIC_SUPABASE_KEY="your_anon_or_publishable_key"
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your_service_role_key"
# Server-only. Required only for legacy HS256 tokens. ES256 (JWT Signing Keys / JWKS) verification uses
# SUPABASE_URL + https://<project>.supabase.co/auth/v1/.well-known/jwks.json — no secret on that path.
# Never put this in NEXT_PUBLIC_* or client bundles. Rotate if leaked.
SUPABASE_JWT_SECRET="your_legacy_jwt_secret_if_you_still_issue_hs256_tokens"

# --- Optional: server-side Next.js → API (defaults shown) ---
# API_INTERNAL_URL=http://127.0.0.1:3000

# --- Next.js apps: leave NEXT_PUBLIC_API_URL empty to use same-origin `/api` (Prisma route handlers) ---
# NEXT_PUBLIC_API_URL=

# --- Admin app (port 3002) — mirror into apps/admin-web/.env.local ---
# NEXT_PUBLIC_* (client) and also SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY (server /api routes; Turbopack may not load repo-root-only secrets for handlers).

# --- Mobile (Expo) — apps/mobile/.env.local ---
# EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key
# EXPO_PUBLIC_SUPABASE_KEY=your_publishable_key
# Vendor Next.js `/api` base (include `/api`; use LAN IP for physical devices):
# EXPO_PUBLIC_VENDOR_API_URL=http://192.168.1.10:3000/api

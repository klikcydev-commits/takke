      "isDeleted": false,
      "boundElements": [],
      "updated": 1768490758621,
      "link": null,
      "locked": false,
      "text": "Self-hosted better-auth:\nWhile e.g. Supabase is a backend hosted\nfor you, you can host a backend yourself\nthat runs better-auth. Gives you full\ncontrol over auth and security, but\nrequires more.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "1o-Idv7xE_dkfy615g3Bc",
      "originalText": "Self-hosted better-auth:\nWhile e.g. Supabase is a backend hosted for you, you can host a backend yourself that runs better-auth. Gives you full control over auth and security, but requires more.",
      "autoResize": true,
      "lineHeight": 1.25
    },

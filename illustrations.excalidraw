    },
    {
      "id": "crmn_fteFqEe6J5rWoA-f",
      "type": "text",
      "x": 14913.433116120148,
      "y": 5295.358787029404,
      "width": 501.42352294921875,
      "height": 60,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],

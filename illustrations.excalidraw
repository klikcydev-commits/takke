      "seed": 1289455129,
      "version": 632,
      "versionNonce": 737967389,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1768490351713,
      "link": null,
      "locked": false,
      "text": "We won't just store the url from Sieve though...\n\nThe URL from Sieve is a presigned URL with an expiration date.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "We won't just store the url from Sieve though...\n\nThe URL from Sieve is a presigned URL with an expiration date.",
      "autoResize": true,
      "lineHeight": 1.25

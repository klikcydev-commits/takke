      "boundElements": [],
      "updated": 1768490351712,
      "link": null,
      "locked": false,
      "text": "Sieve deducts credits from your\naccount on requests - $20 free\ncredits, so no worries :)\n\nJob processing status can also be\nmonitored in the Sieve dashboard and\nlogs seen for debugging for example",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "PiyBvipiHTySjm8MIwZA-",
      "originalText": "Sieve deducts credits from your account on requests - $20 free credits, so no worries :)\n\nJob processing status can also be monitored in the Sieve dashboard and logs seen for debugging for example",

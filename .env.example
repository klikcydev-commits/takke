# Supabase project
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your_publishable_key"
# Optional legacy public aliases:
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_publishable_or_anon_key"
NEXT_PUBLIC_SUPABASE_KEY="your_publishable_or_anon_key"

# Server-side Supabase
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your_service_role_key"

# Optional legacy HS256 only (do not set for modern JWKS-only setups unless needed)
SUPABASE_JWT_SECRET=""

# Optional API base overrides
# NEXT_PUBLIC_API_URL=
# API_INTERNAL_URL=http://127.0.0.1:3000

# Optional auth-link script controls
# LINK_SUPABASE_EMAILS=admin@marketplace.com,vendor@example.com
# LINK_RESET_AUTH_PASSWORD=1
# SEED_DEMO_PASSWORD=ChangeMe123!

# Expo app
# EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key
# EXPO_PUBLIC_SUPABASE_KEY=your_publishable_key
# EXPO_PUBLIC_VENDOR_API_URL=http://127.0.0.1:3000/api

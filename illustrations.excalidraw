      "isDeleted": true,
      "boundElements": [],
      "updated": 1768490391854,
      "link": null,
      "locked": false,
      "text": "These steps are triggered through a queue, to decouple user actions from long-running processes,\nhandle concurrency etc",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "These steps are triggered through a queue, to decouple user actions from long-running processes, handle concurrency etc",
